08003370 <PCF8575_Write>:
int PCF8575_Read(uint16_t devAddr){
	uint8_t pBuffer[2]={0};
	if (HAL_OK == HAL_I2C_Master_Receive(&hi2c2,0x40|(devAddr<<1),pBuffer,2,10)) return (pBuffer[1]<<8 | pBuffer[0]);
	else																		 return -1;
